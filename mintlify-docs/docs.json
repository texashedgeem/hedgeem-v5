{
  "$schema": "https://mintlify.com/docs.json",
  "name": "HedgeEm API",
  "theme": "maple",
  "colors": {
    "primary": "#b45309",
    "light": "#d97706",
    "dark": "#92400e"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Get Started",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "authentication"]
          }
        ]
      },
      {
        "tab": "Concepts",
        "groups": [
          {
            "group": "Concepts",
            "pages": ["concepts/game-states", "concepts/card-notation"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "System",
            "pages": ["api-reference/health"]
          },
          {
            "group": "Game",
            "pages": ["api-reference/deal"]
          },
          {
            "group": "Tables",
            "pages": [
              "api-reference/tables/state",
              "api-reference/tables/advance",
              "api-reference/tables/bet",
              "api-reference/tables/topup",
              "api-reference/tables/sit"
            ]
          },
          {
            "group": "Players",
            "pages": ["api-reference/players/get-player"]
          }
        ]
      }
    ]
  },
  "openapi": "openapi.yaml",
  "footer": {
    "socials": {
      "github": "https://github.com/texashedgeem/hedgeem-v5"
    }
  },
  "favicon": "/images/loading.jpg",
  "logo": "/images/gamblewheel.png",
  "appearance": {
    "default": "dark"
  }
}
